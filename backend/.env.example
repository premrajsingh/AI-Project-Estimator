# ─── AI Model ──────────────────────────────────────────────────────────────────
# Gemini model to use for planning & estimation
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: separate model for estimation agent
GEMINI_MODEL_ESTIMATION=gemini-2.5-flash-lite

# Timeout in seconds for Gemini API calls
GEMINI_TIMEOUT_SECONDS=120

# ─── API Keys ──────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get one at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ─── App ───────────────────────────────────────────────────────────────────────
# JWT secret for auth tokens — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# Comma-separated list of allowed frontend origins (no trailing slash)
# In development this defaults to localhost; in production, set your deployed URL
ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yourapp.com
